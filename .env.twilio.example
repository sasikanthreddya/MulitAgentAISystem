# Copy to .env.twilio and fill in real values. Never commit .env.twilio — it's gitignored.
#
# Kept separate from .env so the generic rest-api server (used for whatever API
# a given story targets) never accidentally picks up Twilio's Basic-auth credentials.
# Loaded directly by the rest-api-twilio MCP server via dotenv-cli, as defined in .mcp.json.

REST_BASE_URL=https://api.twilio.com

# From Twilio Console > Account > API keys & tokens
AUTH_BASIC_USERNAME=
AUTH_BASIC_PASSWORD=
