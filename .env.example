# Copy to .env and fill in real values. Never commit .env — it's gitignored.
#
# Single file for every credential this project needs — all MCP servers and the
# scripted test suite read from this same file (each via its own --env-file flag
# or scripts/run-with-env.mjs), no shell exports or OS environment variables
# needed. Just fill this in and open the project in any Claude Code client
# (Desktop, CLI, VS Code, CI).

# --- Jira (mcp-atlassian) ---
# JIRA_URL: your Atlassian Cloud site, e.g. https://yourcompany.atlassian.net
# JIRA_USERNAME: the Atlassian account email used to generate the API token below
# JIRA_API_TOKEN: a CLASSIC (unscoped) API token from https://id.atlassian.com/manage-profile/security/api-tokens
#   (a "scoped" token missing read:jira-work/write:jira-work will silently fail with empty project lists)
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

# --- Generic REST API under test (rest-api MCP, "api" scripted-suite project) ---
# Base URL of whatever API a given story targets. Defaults to Restful-Booker if unset.
REST_BASE_URL=https://restful-booker.herokuapp.com

# --- Twilio (rest-api-twilio MCP, "ivr" scripted-suite project) ---
# From Twilio Console > Account > API keys & tokens.
# Prefixed distinctly from REST_BASE_URL/AUTH_BASIC_* above on purpose: the
# rest-api and rest-api-twilio MCP servers are two instances of the same
# underlying tool (dkmaker-mcp-rest-api), which always reads those exact
# generic names — run-with-env.mjs's --map remaps these prefixed values to
# the generic ones at spawn time so both instances can share this one file.
TWILIO_BASE_URL=https://api.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Rahul Shetty Academy practice site (tests/ui/checkout-flow.spec.js) ---
# Test account for the practice e-commerce checkout flow. Claude does not fill
# this in or perform the login itself — you run that test yourself.
RAHUL_SHETTY_EMAIL=
RAHUL_SHETTY_PASSWORD=
