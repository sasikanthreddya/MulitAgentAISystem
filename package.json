{
  "name": "agentic-ai-testing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "pretest": "node scripts/clean-target.mjs",
    "test": "playwright test --project=ui --project=api",
    "test:ui": "npm run pretest && playwright test --project=ui",
    "test:ui:headed": "npm run pretest && playwright test --project=ui --headed",
    "test:api": "npm run pretest && playwright test --project=api",
    "test:ivr": "npm run pretest && playwright test --project=ivr",
    "test:all": "npm run pretest && playwright test",
    "report:open": "node -e \"require('child_process').exec(process.platform==='win32'?'start target/extent-report/index.html':'open target/extent-report/index.html')\""
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
